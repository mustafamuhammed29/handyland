{
  "env": {
    "node": true,
    "es2022": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "commonjs"
  },
  "rules": {
    "no-console": "off",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "eqeqeq": "off",
    "no-var": "warn",
    "prefer-const": "off",
    "curly": "off",
    "no-multiple-empty-lines": "off",
    "no-trailing-spaces": "off"
  },
  "ignorePatterns": [
    "node_modules/",
    "uploads/",
    "dist/",
    "*.test.js",
    "test_*.js",
    "seed-*.js",
    "scripts/",
    "admin/",
    "tests/"
  ]
}
