# ── Environment ──────────────────────────────
NODE_ENV=production
PORT=5000

# ── Supabase (replaces MongoDB + JWT) ────────
# REQUIRED IN PRODUCTION
SUPABASE_URL=https://xxxx.supabase.co
# REQUIRED IN PRODUCTION
SUPABASE_ANON_KEY=eyJhbGci...
# REQUIRED IN PRODUCTION (service_role — never expose to frontend)
SUPABASE_SERVICE_KEY=eyJhbGci...
# REQUIRED IN PRODUCTION (for direct DB connection if needed)
DATABASE_URL=postgresql://postgres:[password]@db.xxxx.supabase.co:5432/postgres

# ── CORS & Security ──────────────────────────
# REQUIRED IN PRODUCTION
ALLOWED_ORIGINS=https://handyland.com,https://www.handyland.com
# REQUIRED IN PRODUCTION
RATE_LIMIT_MAX=300
FRONTEND_URL=https://handyland.com
ADMIN_URL=https://admin.handyland.com

# ── Email Services ───────────────────────────
# REQUIRED IN PRODUCTION
REQUIRE_EMAIL_VERIFICATION=true
# REQUIRED IN PRODUCTION
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@handyland.com
FROM_NAME="HandyLand Support"

# ── Stripe Payments ──────────────────────────
# REQUIRED IN PRODUCTION
STRIPE_PUBLISHABLE_KEY=pk_live_your_live_key
STRIPE_SECRET_KEY=sk_live_your_live_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Sentry Error Monitoring ───────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── Social Authentication (via Supabase OAuth) ─
# Configure these in Supabase Dashboard > Auth > Providers
# No need to add them here — Supabase handles OAuth flows

# ── Removed (no longer needed) ───────────────
# MONGO_URI — replaced by Supabase
# JWT_SECRET — Supabase issues JWTs
# REFRESH_TOKEN_SECRET — Supabase manages refresh tokens
# CLOUDINARY_* — replaced by Supabase Storage
