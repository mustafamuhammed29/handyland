# ── Environment ──────────────────────────────
NODE_ENV=production
PORT=5000

# ── Database & Authentication (Supabase) ─────
# REQUIRED IN PRODUCTION
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ── Internal Security ───────────────────────
# REQUIRED IN PRODUCTION (For encryption of settings, not JWTs anymore)
JWT_SECRET=your-strong-random-secret-here

# ── CORS & Security ──────────────────────────
# REQUIRED IN PRODUCTION
ALLOWED_ORIGINS=https://handyland.com,https://www.handyland.com
# REQUIRED IN PRODUCTION
RATE_LIMIT_MAX=300
FRONTEND_URL=https://handyland.com
ADMIN_URL=https://admin.handyland.com

# ── Email Services ───────────────────────────
# REQUIRED IN PRODUCTION
REQUIRE_EMAIL_VERIFICATION=true
# REQUIRED IN PRODUCTION
SMTP_HOST=smtp.sendgrid.net
# REQUIRED IN PRODUCTION
SMTP_PORT=587
# REQUIRED IN PRODUCTION
SMTP_USER=apikey
# REQUIRED IN PRODUCTION
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@handyland.com
FROM_NAME="HandyLand Support"

# ── Stripe Payments ──────────────────────────
# REQUIRED IN PRODUCTION
STRIPE_PUBLISHABLE_KEY=pk_live_your_live_key
# REQUIRED IN PRODUCTION
STRIPE_SECRET_KEY=sk_live_your_live_key
# REQUIRED IN PRODUCTION
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Cloudinary (Image Uploads) ────────────────
# REQUIRED IN PRODUCTION
CLOUDINARY_CLOUD_NAME=your_cloud_name
# REQUIRED IN PRODUCTION
CLOUDINARY_API_KEY=your_api_key
# REQUIRED IN PRODUCTION
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://apikey:apisecret@cloudname

# ── Sentry Error Monitoring ───────────────────
# REQUIRED IN PRODUCTION
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── Social Authentication (Optional) ──────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
